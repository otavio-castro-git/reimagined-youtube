# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o .env no git!

# Flask
SECRET_KEY=coloque-uma-chave-secreta-aleatoria-aqui
FLASK_ENV=development
FLASK_DEBUG=1

# Azure SQL Server
# Encontre esses dados no portal Azure > SQL Database > Connection Strings
DB_SERVER=seu-servidor.database.windows.net
DB_NAME=beattube
DB_USER=seu-usuario
DB_PASSWORD=sua-senha
# Driver ODBC: instale com "sudo apt install unixodbc-dev" + driver da Microsoft
DB_DRIVER=ODBC Driver 18 for SQL Server

# Google OAuth
# Crie em console.cloud.google.com > APIs > Credenciais > OAuth 2.0
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-google-client-secret

# URL base (para redirect OAuth)
BASE_URL=http://localhost:5000

# Google reCAPTCHA v3 (invisível)
# Crie em https://www.google.com/recaptcha/admin -> escolha reCAPTCHA v3
# Adicione "localhost" e o domínio de produção na lista de domínios
RECAPTCHA_SITE_KEY=sua-site-key-aqui
RECAPTCHA_SECRET_KEY=sua-secret-key-aqui
# Nota mínima (0.0 a 1.0) pra considerar a ação humana. 0.5 é o recomendado.
RECAPTCHA_MIN_SCORE=0.5

# Email (Gmail SMTP) — usado para enviar o código de verificação no cadastro
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=project.tube.contact@gmail.com
# Gere uma "senha de app" em https://myaccount.google.com/apppasswords
# (precisa ter a verificação em 2 etapas ativada na conta Google)
MAIL_PASSWORD=sua-senha-de-app-aqui
MAIL_DEFAULT_SENDER=project.tube.contact@gmail.com
